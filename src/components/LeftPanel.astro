---
import profile from '../content/profile.json';

interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;
const isZh = lang === 'zh';
const name = isZh ? profile.name_zh : profile.name_en;
const tags = isZh ? profile.tags_zh : profile.tags_en;
const bio = (isZh ? profile.bio_zh : profile.bio_en).replace('\n', '<br>');
const altLangUrl = isZh ? '/en/' : '/';
---

<aside class="left-panel" id="leftPanel">
  <!-- Background glow layers -->
  <div class="glow-full"></div>
  <div class="glow-center"></div>
  <div class="glow-bottom"></div>
  <div class="glow-edge"></div>

  <div class="left-content">
    <!-- Avatar -->
    <div class="avatar-wrap">
      <div class="avatar-glow" id="avatarGlow"></div>
      <div class="avatar-ring" id="avatarRing"></div>
      <div class="avatar">MW</div>
    </div>

    <!-- Name -->
    <div class="name-block">
      <div class="name-primary">{name}</div>
      <div class="name-sub">{profile.domain}</div>
    </div>

    <!-- Bio tags: 1 top + 3 bottom -->
    <div class="bio-tags">
      <div class="bio-tags-row">
        <span class="bio-tag">{tags[0]}</span>
      </div>
      <div class="bio-tags-row">
        {tags.slice(1).map((tag: string) => (
          <span class="bio-tag">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Bio -->
    <div class="bio" set:html={bio} />

    <!-- Social links -->
    <div class="social-links">
      <a class="social-btn" href={profile.social.jike} target="_blank" rel="noopener" data-label="即刻" title="即刻">
        <svg viewBox="0 0 24 24"><path d="M15 3 V13 C15 17.5 12 20 8 21" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a class="social-btn" href={profile.social.xiaohongshu} target="_blank" rel="noopener" data-label="小红书" title="小红书">
        <svg viewBox="0 0 24 24"><path d="M22.405 9.879c.002.016.01.02.07.019h.725a.797.797 0 0 0 .78-.972.794.794 0 0 0-.884-.618.795.795 0 0 0-.692.794c0 .101-.002.666.001.777zm-11.509 4.808c-.203.001-1.353.004-1.685.003a2.528 2.528 0 0 1-.766-.126.025.025 0 0 0-.03.014L7.7 16.127a.025.025 0 0 0 .01.032c.111.06.336.124.495.124.66.01 1.32.002 1.981 0 .01 0 .02-.006.023-.015l.712-1.545a.025.025 0 0 0-.024-.036zM.477 9.91c-.071 0-.076.002-.076.01a.834.834 0 0 0-.01.08c-.027.397-.038.495-.234 3.06-.012.24-.034.389-.135.607-.026.057-.033.042.003.112.046.092.681 1.523.787 1.74.008.015.011.02.017.02.008 0 .033-.026.047-.044.147-.187.268-.391.371-.606.306-.635.44-1.325.486-1.706.014-.11.021-.22.03-.33l.204-2.616.022-.293c.003-.029 0-.033-.03-.034zm7.203 3.757a1.427 1.427 0 0 1-.135-.607c-.004-.084-.031-.39-.235-3.06a.443.443 0 0 0-.01-.082c-.004-.011-.052-.008-.076-.008h-1.48c-.03.001-.034.005-.03.034l.021.293c.076.982.153 1.964.233 2.946.05.4.186 1.085.487 1.706.103.215.223.419.37.606.015.018.037.051.048.049.02-.003.742-1.642.804-1.765.036-.07.03-.055.003-.112zm3.861-.913h-.872a.126.126 0 0 1-.116-.178l1.178-2.625a.025.025 0 0 0-.023-.035l-1.318-.003a.148.148 0 0 1-.135-.21l.876-1.954a.025.025 0 0 0-.023-.035h-1.56c-.01 0-.02.006-.024.015l-.926 2.068c-.085.169-.314.634-.399.938a.534.534 0 0 0-.02.191.46.46 0 0 0 .23.378.981.981 0 0 0 .46.119h.59c.041 0-.688 1.482-.834 1.972a.53.53 0 0 0-.023.172.465.465 0 0 0 .23.398c.15.092.342.12.475.12l1.66-.001c.01 0 .02-.006.023-.015l.575-1.28a.025.025 0 0 0-.024-.035zm-6.93-4.937H3.1a.032.032 0 0 0-.034.033c0 1.048-.01 2.795-.01 6.829 0 .288-.269.262-.28.262h-.74c-.04.001-.044.004-.04.047.001.037.465 1.064.555 1.263.01.02.03.033.051.033.157.003.767.009.938-.014.153-.02.3-.06.438-.132.3-.156.49-.419.595-.765.052-.172.075-.353.075-.533.002-2.33 0-4.66-.007-6.991a.032.032 0 0 0-.032-.032zm11.784 6.896c0-.014-.01-.021-.024-.022h-1.465c-.048-.001-.049-.002-.05-.049v-4.66c0-.072-.005-.07.07-.07h.863c.08 0 .075.004.075-.074V8.393c0-.082.006-.076-.08-.076h-3.5c-.064 0-.075-.006-.075.073v1.445c0 .083-.006.077.08.077h.854c.075 0 .07-.004.07.07v4.624c0 .095.008.084-.085.084-.37 0-1.11-.002-1.304 0-.048.001-.06.03-.06.03l-.697 1.519s-.014.025-.008.036c.006.01.013.008.058.008 1.748.003 3.495.002 5.243.002.03-.001.034-.006.035-.033v-1.539zm4.177-3.43c0 .013-.007.023-.02.024-.346.006-.692.004-1.037.004-.014-.002-.022-.01-.022-.024-.005-.434-.007-.869-.01-1.303 0-.072-.006-.071.07-.07l.733-.003c.041 0 .081.002.12.015.093.025.16.107.165.204.006.431.002 1.153.001 1.153zm2.67.244a1.953 1.953 0 0 0-.883-.222h-.18c-.04-.001-.04-.003-.042-.04V10.21c0-.132-.007-.263-.025-.394a1.823 1.823 0 0 0-.153-.53 1.533 1.533 0 0 0-.677-.71 2.167 2.167 0 0 0-1-.258c-.153-.003-.567 0-.72 0-.07 0-.068.004-.068-.065V7.76c0-.031-.01-.041-.046-.039H17.93s-.016 0-.023.007c-.006.006-.008.012-.008.023v.546c-.008.036-.057.015-.082.022h-.95c-.022.002-.028.008-.03.032v1.481c0 .09-.004.082.082.082h.913c.082 0 .072.128.072.128V11.19s.003.117-.06.117h-1.482c-.068 0-.06.082-.06.082v1.445s-.01.068.064.068h1.457c.082 0 .076-.006.076.079v3.225c0 .088-.007.081.082.081h1.43c.09 0 .082.007.082-.08v-3.27c0-.029.006-.035.033-.035l2.323-.003c.098 0 .191.02.28.061a.46.46 0 0 1 .274.407c.008.395.003.79.003 1.185 0 .259-.107.367-.33.367h-1.218c-.023.002-.029.008-.028.033.184.437.374.871.57 1.303a.045.045 0 0 0 .04.026c.17.005.34.002.51.003.15-.002.517.004.666-.01a2.03 2.03 0 0 0 .408-.075c.59-.18.975-.698.976-1.313v-1.981c0-.128-.01-.254-.034-.38 0 .078-.029-.641-.724-.998z" fill="currentColor"/></svg>
      </a>
      <a class="social-btn" href={profile.social.github} target="_blank" rel="noopener" data-label="GitHub" title="GitHub">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z" fill="currentColor"/></svg>
      </a>
    </div>

    <!-- Language switch -->
    <div class="lang-switch">
      <a class:list={['lang-btn', { active: isZh }]} href="/" onclick="localStorage.setItem('lang','zh')">中文</a>
      <a class:list={['lang-btn', { active: !isZh }]} href="/en/" onclick="localStorage.setItem('lang','en')">EN</a>
    </div>
  </div>
</aside>

<style>
  .left-panel {
    width: 420px;
    min-width: 380px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 60px 48px;
    overflow: hidden;
    background: var(--color-bg-deep);
  }

  /* Background glow layers */
  .glow-full {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 25% 15%, var(--current-theme, #00F0FF), transparent 55%),
                radial-gradient(ellipse at 75% 85%, var(--current-theme, #00F0FF), transparent 45%);
    opacity: 0.16;
    transition: all 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .glow-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 180%;
    height: 180%;
    background: radial-gradient(circle at 50% 50%, var(--current-theme, #00F0FF), transparent 45%);
    opacity: 0.08;
    transition: all 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    filter: blur(40px);
  }

  .glow-bottom {
    position: absolute;
    bottom: -5%;
    left: 50%;
    transform: translateX(-50%);
    width: 140%;
    height: 45%;
    background: radial-gradient(ellipse at 50% 100%, var(--current-theme, #00F0FF), transparent 55%);
    opacity: 0.2;
    transition: all 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    filter: blur(20px);
  }

  .glow-edge {
    position: absolute;
    top: 0;
    right: 0;
    width: 2px;
    height: 100%;
    background: linear-gradient(180deg, transparent 5%, var(--current-theme, #00F0FF) 50%, transparent 95%);
    opacity: 0.45;
    transition: all 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .left-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 300px;
  }

  /* Avatar */
  .avatar-wrap {
    position: relative;
    width: 110px;
    height: 110px;
  }

  .avatar {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a1a2e, #13131f);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    font-weight: 600;
    color: var(--color-text-secondary);
    position: relative;
    z-index: 1;
    overflow: hidden;
    border: 1.5px solid color-mix(in srgb, var(--current-theme, #00F0FF) 30%, transparent);
    transition: border-color 1s ease;
  }

  .avatar-glow {
    position: absolute;
    inset: -16px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--current-theme, #00F0FF), transparent 70%);
    opacity: 0.15;
    animation: avatar-breathe 4s ease-in-out infinite;
    transition: background 1s ease;
    pointer-events: none;
  }

  .avatar-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid var(--current-theme, #00F0FF);
    opacity: 0;
    animation: avatar-ring-breathe 4s ease-in-out infinite;
    transition: border-color 1s ease;
    pointer-events: none;
  }

  /* Name */
  .name-block {
    text-align: center;
  }

  .name-primary {
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.5px;
    line-height: 1.2;
  }

  .name-sub {
    font-size: 12px;
    color: var(--color-text-tertiary);
    margin-top: 6px;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 1px;
  }

  /* Bio tags */
  .bio-tags {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .bio-tags-row {
    display: flex;
    gap: 8px;
    justify-content: center;
  }

  .bio-tag {
    font-size: 12px;
    padding: 5px 14px;
    border-radius: 100px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  /* Bio */
  .bio {
    font-size: 13px;
    line-height: 1.9;
    color: var(--color-text-secondary);
    text-align: center;
  }

  /* Social */
  .social-links {
    display: flex;
    gap: 12px;
  }

  .social-btn {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
    text-decoration: none;
  }

  .social-btn svg {
    width: 18px;
    height: 18px;
    fill: var(--color-text-secondary);
    transition: fill 0.25s ease;
  }

  .social-btn::after {
    content: attr(data-label);
    position: absolute;
    bottom: -24px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    color: var(--color-text-tertiary);
    opacity: 0;
    transition: all 0.2s ease;
    white-space: nowrap;
    pointer-events: none;
  }

  .social-btn:hover {
    border-color: var(--current-theme, #00F0FF);
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3), 0 0 20px color-mix(in srgb, var(--current-theme, #00F0FF) 10%, transparent);
  }

  .social-btn:hover svg { fill: var(--current-theme, #00F0FF); }
  .social-btn:hover::after { opacity: 1; bottom: -22px; }

  /* Language switch */
  .lang-switch {
    display: flex;
    align-items: center;
    font-size: 12px;
    margin-top: 4px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .lang-btn {
    padding: 6px 16px;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--color-text-tertiary);
    user-select: none;
    text-decoration: none;
  }

  .lang-btn.active {
    background: color-mix(in srgb, var(--current-theme, #00F0FF) 8%, transparent);
    color: var(--current-theme, #00F0FF);
  }

  .lang-btn:not(.active):hover {
    color: var(--color-text-secondary);
    background: rgba(255, 255, 255, 0.02);
  }

  /* Tablet */
  @media (max-width: 1023px) and (min-width: 768px) {
    .left-panel {
      width: 320px;
      min-width: 280px;
      padding: 40px 32px;
    }

    .left-content {
      gap: 16px;
    }

    .avatar-wrap, .avatar {
      width: 90px;
      height: 90px;
    }

    .avatar { font-size: 28px; }

    .name-block .name-primary { font-size: 24px; }

    .bio-tag { font-size: 11px; padding: 4px 12px; }
    .bio { font-size: 12px; }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .left-panel {
      width: 100%;
      min-width: unset;
      padding: 40px 24px 32px;
      border-right: none;
      border-bottom: 2px solid var(--current-theme, #00F0FF);
      position: relative;
    }

    .glow-edge {
      /* Move from right edge to bottom */
      top: auto;
      right: auto;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg, transparent 5%, var(--current-theme, #00F0FF) 50%, transparent 95%);
    }

    .left-content {
      gap: 14px;
      max-width: 100%;
    }

    .avatar-wrap, .avatar {
      width: 80px;
      height: 80px;
    }

    .avatar { font-size: 24px; }
    .avatar-glow { inset: -12px; }
    .avatar-ring { inset: -4px; }

    .name-block .name-primary {
      font-size: 20px;
    }

    .name-sub { font-size: 11px; }

    .bio-tags-row { gap: 6px; }
    .bio-tag {
      font-size: 10px;
      padding: 4px 10px;
    }

    .bio {
      font-size: 12px;
      line-height: 1.7;
    }

    .social-links { gap: 10px; }
    .social-btn {
      width: 38px;
      height: 38px;
      border-radius: 10px;
    }
    .social-btn svg {
      width: 16px;
      height: 16px;
    }
    .social-btn::after { display: none; }

    .lang-switch { font-size: 11px; }
    .lang-btn { padding: 5px 14px; }
  }
</style>
