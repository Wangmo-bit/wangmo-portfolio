---
import ProjectCard from './ProjectCard.astro';
import projects from '../content/projects.json';
import press from '../content/press.json';

interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;
const isZh = lang === 'zh';
const sortedProjects = [...projects].sort((a, b) => a.order - b.order);
const hasPress = press.length > 0;
---

<main class="right-panel" id="rightPanel">
  <div class="section-header">
    <span class="section-label">{isZh ? '作品' : 'Projects'}</span>
    <div class="section-line"></div>
    <span class="section-count">{String(sortedProjects.length).padStart(2, '0')}</span>
  </div>

  {sortedProjects.map((project, i) => (
    <ProjectCard project={project} isFirst={i === 0} lang={lang} />
  ))}

  {hasPress && (
    <div class="press-section">
      <div class="section-header">
        <span class="section-label">{isZh ? '媒体报道' : 'Press'}</span>
        <div class="section-line"></div>
      </div>
      {press.map((item: any) => (
        <a class="press-item" href={item.url} target="_blank" rel="noopener">
          <div>
            <div class="press-title">{isZh ? item.title_zh : item.title_en}</div>
            <div class="press-meta">{item.source} · {item.date}</div>
          </div>
          <div class="press-arrow">↗</div>
        </a>
      ))}
    </div>
  )}

  <div class="footer">
    <span>{isZh ? '© 2026 王墨 · 用好奇心搭建' : '© 2026 Mo Wang · Built with curiosity'}</span>
  </div>
</main>

<style>
  .right-panel {
    flex: 1;
    overflow-y: auto;
    padding: 48px 56px 160px;
    scroll-behavior: smooth;
    background: var(--color-bg-elevated);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeInUp 0.5s ease forwards;
    animation-delay: 0.1s;
  }

  .section-label {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    font-family: 'JetBrains Mono', monospace;
  }

  .section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--color-border), transparent);
  }

  .section-count {
    font-size: 11px;
    color: var(--color-text-tertiary);
    font-family: 'JetBrains Mono', monospace;
  }

  .press-section {
    margin-top: 48px;
  }

  .press-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    margin-bottom: 10px;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
  }

  .press-item:hover {
    border-color: var(--color-border-hover);
    background: var(--color-bg-card);
    transform: translateX(4px);
  }

  .press-title {
    font-size: 14px;
    color: var(--color-text-primary);
    margin-bottom: 4px;
  }

  .press-meta {
    font-size: 11px;
    color: var(--color-text-tertiary);
    font-family: 'JetBrains Mono', monospace;
  }

  .press-arrow {
    font-size: 16px;
    color: var(--color-text-tertiary);
    transition: color 0.25s;
  }

  .press-item:hover .press-arrow {
    color: var(--color-text-secondary);
  }

  .footer {
    text-align: center;
    padding: 60px 0 20px;
    font-size: 12px;
    color: var(--color-text-tertiary);
  }
</style>
