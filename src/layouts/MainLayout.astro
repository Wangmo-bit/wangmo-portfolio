---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  description = 'Mo Wang — 产品创造者，梅乾资本创始人。作品展示与个人介绍。',
  lang = 'zh',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="keywords" content="王墨, Mo Wang, 梅乾资本, Dry Capital, CyberLife, 赛博生活, 独立开发, portfolio" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="wangmo.tech" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Language auto-detect: redirect first-time visitors based on browser lang -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('lang');
        if (saved) return; // user already chose
        var path = location.pathname;
        var isRoot = path === '/' || path === '/index.html';
        var isEn = path.startsWith('/en');
        var browserEn = !navigator.language.startsWith('zh');
        if (browserEn && isRoot) {
          localStorage.setItem('lang', 'en');
          location.replace('/en/');
        } else if (!browserEn && isEn) {
          localStorage.setItem('lang', 'zh');
          location.replace('/');
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
