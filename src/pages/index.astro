---
import MainLayout from '../layouts/MainLayout.astro';
import LeftPanel from '../components/LeftPanel.astro';
import RightPanel from '../components/RightPanel.astro';
---

<MainLayout title="王墨的赛博分身 — Mo Wang" lang="zh">
  <div class="container">
    <LeftPanel lang="zh" />
    <RightPanel lang="zh" />
  </div>
</MainLayout>

<style>
  .container {
    display: flex;
    height: 100vh;
  }

  @media (max-width: 1023px) and (min-width: 768px) {
    .container {
      display: flex;
      height: 100vh;
    }
  }

  @media (max-width: 767px) {
    .container {
      flex-direction: column;
      height: auto;
      min-height: 100vh;
    }
  }
</style>

<script>
  const leftPanel = document.getElementById('leftPanel')!;
  const rightPanel = document.getElementById('rightPanel')!;
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  let currentTheme = '#00F0FF';

  function updateTheme() {
    const isMobile = window.innerWidth < 768;
    const scrollTarget = isMobile ? document.documentElement : rightPanel;
    const viewportCenter = isMobile
      ? window.innerHeight * 0.4
      : rightPanel.getBoundingClientRect().top + rightPanel.getBoundingClientRect().height * 0.4;

    let closestCard: HTMLElement | null = null;
    let closestDist = Infinity;

    cards.forEach(card => {
      const rect = card.getBoundingClientRect();
      const cardCenter = rect.top + rect.height / 2;
      const dist = Math.abs(cardCenter - viewportCenter);
      if (dist < closestDist) {
        closestDist = dist;
        closestCard = card;
      }
    });

    if (closestCard) {
      const theme = (closestCard as HTMLElement).dataset.theme!;
      if (theme !== currentTheme) {
        currentTheme = theme;
        leftPanel.style.setProperty('--current-theme', theme);
      }
      cards.forEach(c => c.classList.remove('active'));
      closestCard.classList.add('active');
    }
  }

  rightPanel.addEventListener('scroll', updateTheme);
  window.addEventListener('scroll', updateTheme);

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const wasExpanded = card.classList.contains('expanded');
      cards.forEach(c => c.classList.remove('expanded'));
      if (!wasExpanded) {
        card.classList.add('expanded');
      }
    });
  });
</script>
